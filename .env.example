# Entra app registration (see README for setup)
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_SECRET=your-client-secret-value

# Must exactly match a Redirect URI in your Entra app registration.
# Local dev:   http://localhost:3000/api/auth/callback
# Production:  https://your-app.vercel.app/api/auth/callback
AZURE_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Random string, 32+ chars, used to encrypt the session cookie.
# Generate with:  openssl rand -base64 32
SESSION_SECRET=replace-with-a-long-random-string-at-least-32-chars
